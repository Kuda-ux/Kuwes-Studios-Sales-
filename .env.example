# --- Database ---
# Local Postgres example. For SQLite during dev, set provider="sqlite" in prisma/schema.prisma and use file:./dev.db
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kuwex?schema=public"

# --- Messaging provider ---
# "simulator" (default, browser-based testing) or "twilio"
MESSAGING_PROVIDER="simulator"

# --- Twilio (only required when MESSAGING_PROVIDER=twilio) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Twilio sandbox: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# --- Admin auth (simple shared secret for Phase 1) ---
ADMIN_PASSWORD="change-me"

# --- Public app URL (used in admin links and webhook config) ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
